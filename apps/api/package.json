{
  "name": "@collegechoice/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:online": "tsx prisma/online.ts",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "ingest": "tsx src/ingest/run.ts",
    "db:load:aicte": "tsx src/ingest/aicte.ts",
    "seed:featured": "tsx src/ingest/featured.ts",
    "seed:nirf": "tsx src/ingest/nirf.ts",
    "seed:online": "tsx src/ingest/onlineUniversities.ts",
    "images": "tsx src/ingest/images.ts",
    "images:cities": "tsx src/ingest/cityImages.ts",
    "enrich": "tsx src/ingest/enrich.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "groq-sdk": "^1.3.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.17.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
