# Postgres connection (Prisma)
DATABASE_URL=postgresql://collegechoice:change_me_in_production@localhost:5432/collegechoice

# Server
API_PORT=4000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=replace_with_a_long_random_secret

# Google Sheets lead sink — apply/enquiry submissions are mirrored to a Google
# Sheet in real time. Paste the Apps Script Web App URL here (see ARCHITECTURE.md).
# Leave blank to disable (leads still save to the DB either way).
GOOGLE_SHEETS_WEBHOOK_URL=
# Shared secret the Apps Script checks to reject spoofed POSTs (any long random string).
GOOGLE_SHEETS_SECRET=
