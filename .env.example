# ── Database ───────────────────────────────────────────────
# Used by docker-compose to provision Postgres
POSTGRES_USER=collegechoice
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=collegechoice

# Connection string consumed by the API (Prisma).
# Local dev (Postgres on host):  postgresql://collegechoice:change_me_in_production@localhost:5432/collegechoice
# Docker compose (service name): postgresql://collegechoice:change_me_in_production@db:5432/collegechoice
DATABASE_URL=postgresql://collegechoice:change_me_in_production@localhost:5432/collegechoice

# ── API ────────────────────────────────────────────────────
API_PORT=4000
# Comma-separated origins allowed to call the API
CORS_ORIGIN=http://localhost:3000
# Secret for signing JWTs — generate a long random string in production
JWT_SECRET=replace_with_a_long_random_secret

# ── AI Enrichment ─────────────────────────────────────────
# Groq API key — free tier (6k req/day, Llama 3.3 70B), no billing needed.
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=

# ── Web (Next.js) ──────────────────────────────────────────
# Public base URL of the API the browser/SSR will call
NEXT_PUBLIC_API_URL=http://localhost:4000
